---
interface Props {
  type?: 'note' | 'tip' | 'warning';
  title?: string;
}

const { type = 'note', title } = Astro.props;
const label = title ?? (type === 'warning' ? 'Important' : type === 'tip' ? 'Tip' : 'Note');
---

<aside class={`callout callout-${type}`}>
  <div class="callout-label">{label}</div>
  <div class="callout-body">
    <slot />
  </div>
</aside>
